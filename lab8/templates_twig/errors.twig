{% extends "layout.twig" %}

{% block title %}Ошибки{% endblock %}

{% block content %}
<div class="card">
    <h1>Ошибки валидации</h1>

    <ul class="error-list">
        {% for error in errors %}
            <li>{{ error }}</li>
        {% endfor %}
    </ul>

    <div class="actions">
        <a href="{{ back_url|default('index_twig.php') }}" class="btn">Назад</a>
        <a href="list_sessions_twig.php" class="btn btn-secondary">Список</a>
    </div>
</div>
{% endblock %}