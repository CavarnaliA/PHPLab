{% extends "layout.twig" %}

{% block title %}Редактирование записи{% endblock %}

{% block content %}
<div class="card">
    <h1>Редактирование учебной сессии</h1>

    {% if errors is not empty %}
        <ul class="error-list">
            {% for error in errors %}
                <li>{{ error }}</li>
            {% endfor %}
        </ul>
    {% endif %}

    <form action="edit_twig.php" method="POST" class="form">
        <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
        <input type="hidden" name="id" value="{{ session.id }}">

        <div class="form-group">
            <label>Предмет</label>
            <input type="text" name="subject" value="{{ session.subject }}" required minlength="2" maxlength="100">
        </div>

        <div class="form-group">
            <label>Дата</label>
            <input type="date" name="study_date" value="{{ session.study_date }}" required>
        </div>

        <div class="form-group">
            <label>Длительность (мин)</label>
            <input type="number" name="duration" value="{{ session.duration }}" required min="1" max="600">
        </div>

        <div class="form-group">
            <label>Сложность</label>
            <select name="difficulty" required>
                <option value="">Выберите</option>
                <option value="Легко" {% if session.difficulty == 'Легко' %}selected{% endif %}>Легко</option>
                <option value="Средне" {% if session.difficulty == 'Средне' %}selected{% endif %}>Средне</option>
                <option value="Сложно" {% if session.difficulty == 'Сложно' %}selected{% endif %}>Сложно</option>
            </select>
        </div>

        <div class="form-group">
            <label>Результат</label>
            <select name="result" required>
                <option value="">Выберите</option>
                <option value="Выполнено" {% if session.result == 'Выполнено' %}selected{% endif %}>Выполнено</option>
                <option value="Частично" {% if session.result == 'Частично' %}selected{% endif %}>Частично</option>
                <option value="Нужно повторить" {% if session.result == 'Нужно повторить' %}selected{% endif %}>Нужно повторить</option>
            </select>
        </div>

        <div class="form-group">
            <label>Заметки</label>
            <textarea name="notes" required minlength="5" maxlength="1000">{{ session.notes }}</textarea>
        </div>

        <div class="actions">
            <button type="submit" class="btn">Сохранить изменения</button>
            <a href="list_sessions_twig.php" class="btn btn-secondary">Назад</a>
        </div>
    </form>
</div>
{% endblock %}