{% extends "layout.twig" %}

{% block title %}Ошибки{% endblock %}

{% block content %}
<div class="card">
    <h1>Ошибки валидации</h1>

    <ul>
        {% for error in errors %}
            <li>{{ error }}</li>
        {% endfor %}
    </ul>

    <div class="actions">
        <a href="index_twig.php" class="btn">Назад</a>
    </div>
</div>
{% endblock %}